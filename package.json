{
  "name": "1coos-skills",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "1COOS Claude Code Skills 开发与发布项目",
  "workspaces": [
    "packages/*",
    "skills/*/scripts"
  ],
  "scripts": {
    "test": "bun test",
    "new-skill": "bun run scripts/init-skill.ts",
    "validate": "bun run scripts/validate.ts",
    "package": "bun run scripts/package-plugin.ts",
    "package:all": "bun run scripts/package-plugin.ts --all",
    "publish": "bun run scripts/publish.ts"
  },
  "dependencies": {
    "@1coos/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
